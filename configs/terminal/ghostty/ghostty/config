command = /usr/bin/fish
title = Terminal
shell-integration = fish
term = xterm-kitty
window-decoration = true
window-theme = ghostty
window-height = 255
window-width = 500
background = #000000
selection-background = #ffffff
selection-foreground = #5e5c64
keybind = ctrl+shift+l=new_split:right
keybind = ctrl+shift+j=new_split:down
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:bottom
keybind = super+alt+k=goto_split:top
keybind = super+alt+l=goto_split:right
cursor-color = #ffffff
cursor-text = #1e1e1e
cursor-style = bar
palette = 0=#241f31
palette = 1=#c01c28
palette = 2=#2ec27e
palette = 3=#f5c211
palette = 4=#1e78e4
palette = 5=#9841bb
palette = 6=#0ab9dc
palette = 7=#c0bfbc
palette = 8=#5e5c64
palette = 9=#ed333b
palette = 10=#57e389
palette = 11=#f8e45c
palette = 12=#51a1ff
palette = 13=#c061cb
palette = 14=#4fd2fd
palette = 15=#f6f5f4
font-size = 11

#font-family = RobotoMono Nerd Font
#font-family-bold = RobotoMono Nerd Font
#font-family-italic = RobotoMono Nerd Font
#font-family-bold-italic = RobotoMono Nerd Font
#font-style = RobotoMono Nerd Font
#font-style-bold = RobotoMono Nerd Font
#font-style-italic = RobotoMono Nerd Font
#font-style-bold-italic = RobotoMono Nerd Font

font-family = JetBrainsMono Nerd Font
font-family-bold = JetBrainsMono Nerd Font
font-family-italic = JetBrainsMono Nerd Font
font-family-bold-italic = JetBrainsMono Nerd Font

#font-family = FiraCode Nerd Font
#font-family-bold = FiraCode Nerd Font
#font-family-italic = FiraCode Nerd Font
#font-family-bold-italic = FiraCode Nerd Font
#font-style = FiraCode Nerd Font
#font-style-bold = FiraCode Nerd Font
#font-style-italic = FiraCode Nerd Font
#font-style-bold-italic = FiraCode Nerd Font
keybind = shift+enter=text:\n
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size
