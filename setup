restore_dev_configs() {
    print_section "RESTORING DEVELOPMENT TOOL CONFIGURATIONS"

    local home_dir=$(get_home_dir)
    local config_dir="$home_dir/.config"

    # Lazygit
    if [ -d "$SCRIPT_DIR/configs/dev/lazygit/lazygit" ]; then
        print_step "Restoring Lazygit configuration..."
        ensure_directory "$config_dir"
        cp -r "$SCRIPT_DIR/configs/dev/lazygit/lazygit" "$config_dir/"
        print_success "Lazygit configuration restored"
    fi

    # Lazydocker
    if [ -d "$SCRIPT_DIR/configs/dev/lazydocker/lazydocker" ]; then
        print_step "Restoring Lazydocker configuration..."
        ensure_directory "$config_dir"
        cp -r "$SCRIPT_DIR/configs/dev/lazydocker/lazydocker" "$config_dir/"
        print_success "Lazydocker configuration restored"
    fi

    # Linters
    if [ -d "$SCRIPT_DIR/configs/dev/linters" ]; then
        print_step "Restoring linter configurations..."
        [ -f "$SCRIPT_DIR/configs/dev/linters/.eslintrc.js" ] && cp "$SCRIPT_DIR/configs/dev/linters/.eslintrc.js" "$home_dir/"
        [ -f "$SCRIPT_DIR/configs/dev/linters/.eslintrc.json" ] && cp "$SCRIPT_DIR/configs/dev/linters/.eslintrc.json" "$home_dir/"
        [ -f "$SCRIPT_DIR/configs/dev/linters/.luacheckrc" ] && cp "$SCRIPT_DIR/configs/dev/linters/.luacheckrc" "$home_dir/"
        [ -f "$SCRIPT_DIR/configs/dev/linters/.golangci.yml" ] && cp "$SCRIPT_DIR/configs/dev/linters/.golangci.yml" "$home_dir/"
        [ -f "$SCRIPT_DIR/configs/dev/linters/.mypy.ini" ] && cp "$SCRIPT_DIR/configs/dev/linters/.mypy.ini" "$home_dir/"
        [ -f "$SCRIPT_DIR/configs/dev/linters/.pylintrc" ] && cp "$SCRIPT_DIR/configs/dev/linters/.pylintrc" "$home_dir/"
        [ -f "$SCRIPT_DIR/configs/dev/linters/.yamllint.yml" ] && cp "$SCRIPT_DIR/configs/dev/linters/.yamllint.yml" "$home_dir/"
        print_success "Linter configurations restored"
    fi

    # Docker
    if [ -d "$SCRIPT_DIR/configs/dev/docker" ]; then
        print_step "Restoring Docker configuration..."
        ensure_directory "$home_dir/.docker"
        [ -f "$SCRIPT_DIR/configs/dev/docker/config.json" ] && cp "$SCRIPT_DIR/configs/dev/docker/config.json" "$home_dir/.docker/"
        [ -f "$SCRIPT_DIR/configs/dev/docker/daemon.json" ] && sudo cp "$SCRIPT_DIR/configs/dev/docker/daemon.json" /etc/docker/ 2>/dev/null
        print_success "Docker configuration restored"
    fi
}

restore_app_configs() {
    print_section "RESTORING APPLICATION CONFIGURATIONS"

    local home_dir=$(get_home_dir)
    local config_dir="$home_dir/.config"

    # System monitors
    [ -d "$SCRIPT_DIR/configs/apps/btop" ] && cp -r "$SCRIPT_DIR/configs/apps/btop" "$config_dir/" && print_success "btop config restored"
    [ -d "$SCRIPT_DIR/configs/apps/fastfetch" ] && cp -r "$SCRIPT_DIR/configs/apps/fastfetch" "$config_dir/" && print_success "fastfetch config restored"

    # Audio/Video
    [ -d "$SCRIPT_DIR/configs/apps/cava" ] && cp -r "$SCRIPT_DIR/configs/apps/cava" "$config_dir/" && print_success "cava config restored"
    [ -d "$SCRIPT_DIR/configs/apps/mpv" ] && cp -r "$SCRIPT_DIR/configs/apps/mpv" "$config_dir/" && print_success "mpv config restored"

    # Utilities
    [ -d "$SCRIPT_DIR/configs/apps/dunst" ] && cp -r "$SCRIPT_DIR/configs/apps/dunst" "$config_dir/" && print_success "dunst config restored"
    [ -d "$SCRIPT_DIR/configs/apps/fuzzel" ] && cp -r "$SCRIPT_DIR/configs/apps/fuzzel" "$config_dir/" && print_success "fuzzel config restored"
    [ -d "$SCRIPT_DIR/configs/apps/wlogout" ] && cp -r "$SCRIPT_DIR/configs/apps/wlogout" "$config_dir/" && print_success "wlogout config restored"
    [ -d "$SCRIPT_DIR/configs/apps/wofi" ] && cp -r "$SCRIPT_DIR/configs/apps/wofi" "$config_dir/" && print_success "wofi config restored"
    [ -d "$SCRIPT_DIR/configs/apps/gammastep" ] && cp -r "$SCRIPT_DIR/configs/apps/gammastep" "$config_dir/" && print_success "gammastep config restored"
    [ -d "$SCRIPT_DIR/configs/apps/yazi" ] && cp -r "$SCRIPT_DIR/configs/apps/yazi" "$config_dir/" && print_success "yazi config restored"

    # Other apps
    [ -d "$SCRIPT_DIR/configs/apps/obsidian" ] && cp -r "$SCRIPT_DIR/configs/apps/obsidian" "$config_dir/" && print_success "obsidian config restored"
    [ -d "$SCRIPT_DIR/configs/apps/beekeeper-studio" ] && cp -r "$SCRIPT_DIR/configs/apps/beekeeper-studio" "$config_dir/" && print_success "beekeeper-studio config restored"

    # WhatsApp
    if [ -d "$SCRIPT_DIR/configs/apps/whatsapp/WhatsApp-linux-x64" ]; then
        print_step "Restoring WhatsApp Nativefier..."
        ensure_directory "$home_dir/.local/share/applications"
        cp -r "$SCRIPT_DIR/configs/apps/whatsapp/WhatsApp-linux-x64" "$home_dir/.local/share/applications/"
        chmod +x "$home_dir/.local/share/applications/WhatsApp-linux-x64/WhatsApp"
        print_success "WhatsApp application restored"
    fi

    # Desktop entries
    if [ -d "$SCRIPT_DIR/configs/apps/desktop-entries" ]; then
        print_step "Restoring custom desktop entries..."
        ensure_directory "$home_dir/.local/share/applications"
        cp "$SCRIPT_DIR/configs/apps/desktop-entries"/*.desktop "$home_dir/.local/share/applications/" 2>/dev/null
        print_success "Desktop entries restored"
    fi

    # Custom icons
    if [ -d "$SCRIPT_DIR/configs/apps/icons" ]; then
        print_step "Restoring custom icons..."
        ensure_directory "$home_dir/.local/share/icons"
        cp -r "$SCRIPT_DIR/configs/apps/icons"/* "$home_dir/.local/share/icons/" 2>/dev/null
        print_success "Custom icons restored"
    fi

    # Update desktop database
    print_step "Updating desktop database..."
    update-desktop-database "$home_dir/.local/share/applications" &> /dev/null
    print_success "Desktop database updated"
}

