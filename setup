#!/bin/bash
# Chima - Arch Linux Installation Script.
# Post-installation setup script for a complete Hyprland environment.

# Get script directory:
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source libraries:
source "$SCRIPT_DIR/lib/colors.sh"
source "$SCRIPT_DIR/lib/functions.sh"
source "$SCRIPT_DIR/lib/packages.sh"

INSTALL_SUMMARY=()
INSTALL_OFFICIAL=true
INSTALL_AUR=true
INSTALL_CONFIGS=true
INSTALL_OPTIONAL=false
INSTALL_GCLOUD=false
INSTALL_PCLOUD=false
INSTALL_CLAUDE=false
INSTALL_GITHUB=false
INSTALL_FLATPAK=true
INSTALL_NPM=true

show_welcome() {
    clear
    local term_width=$(get_terminal_width)

    local logo_width=51
    local padding=0
    if [[ $term_width -gt $logo_width ]]; then
        padding=$(( (term_width - logo_width) / 2 ))
    fi

    print_logo_line() {
        if [[ $padding -gt 0 ]]; then
            printf "%${padding}s" ""
        fi
        echo -e "${GOLD}$1${NC}"
    }

    echo ""
    print_logo_line " ██████ ██   ██ ██ ███    ███  █████ "
    print_logo_line "██      ██   ██ ██ ████  ████ ██   ██"
    print_logo_line "██      ███████ ██ ██ ████ ██ ███████"
    print_logo_line "██      ██   ██ ██ ██  ██  ██ ██   ██"
    print_logo_line " ██████ ██   ██ ██ ██      ██ ██   ██"
    echo ""

    local subtitle="Arch Linux Installer"
    local sub_padding=0
    if [[ $term_width -gt ${#subtitle} ]]; then
        sub_padding=$(( (term_width - ${#subtitle}) / 2 ))
    fi
    printf "%${sub_padding}s" ""
    echo -e "${CYAN}${subtitle}${NC}"

    local version="Version 1.0.0"
    local ver_padding=0
    if [[ $term_width -gt ${#version} ]]; then
        ver_padding=$(( (term_width - ${#version}) / 2 ))
    fi
    printf "%${ver_padding}s" ""
    echo -e "${CYAN}${version}${NC}"
    echo ""

    echo -e "${CYAN}This script will install and configure a complete Hyprland environment.${NC}"
    echo -e "${CYAN}It includes:${NC}"
    echo -e "  ${GOLD}*${NC} Hyprland Window Manager and utilities"
    echo -e "  ${GOLD}*${NC} Quickshell widgets and customizations"
    echo -e "  ${GOLD}*${NC} SDDM Display Manager for graphical logins"
    echo -e "  ${GOLD}*${NC} Development tools and applications"
    echo -e "  ${GOLD}*${NC} Custom GRUB theme and bootloader setup"
    echo -e "  ${GOLD}*${NC} Custom themes and fonts"
    echo -e "  ${GOLD}*${NC} Custom system configurations and dotfiles"
    echo ""

    echo -e "This script is designed to run after an Arch Linux basic installation."
    echo -e "Estimated installation time: 30-60 minutes."

    if ! confirm_action "Start installation?" "y"; then
        print_error "Installation cancelled."
        exit 0
    fi
}

perform_system_checks() {
    clear_screen
    print_section "SYSTEM CHECKS"

    print_step "Checking operating system..."
    check_arch_linux
    print_success "Arch Linux installation detected."

    print_step "Testing internet connectivity..."
    check_internet

    print_step "Checking available disk space..."
    check_disk_space 10

    print_success "System check was successfull."
    sleep 5
    INSTALL_SUMMARY+=("System check was successfull.")
}

select_installation_mode() {
    local options=(
        "Full Installation"
        "Minimal Installation"
        "Custom Installation"
    )

    show_menu "Select installation mode:" "${options[@]}"
    local choice=$?

    case $choice in
        0) # Full Installation
            INSTALL_CLAUDE=true
            INSTALL_GITHUB=true
            INSTALL_GCLOUD=true
            INSTALL_PCLOUD=true
            INSTALL_OPTIONAL=true
            print_success "Full installation selected."
            ;;
        1) # Minimal Installation
            INSTALL_CLAUDE=false
            INSTALL_GITHUB=false
            INSTALL_GCLOUD=false
            INSTALL_PCLOUD=false
            INSTALL_OPTIONAL=false
            print_success "Minimal installation selected."
            ;;
        2) # Custom Installation
            select_optional_packages
            print_success "Custom installation configured."
            ;;
    esac

    INSTALL_SUMMARY+=("Installation mode configured.")
}

select_optional_packages() {
    local options=(
        "Claude Code"
        "GitHub CLI"
        "Google Cloud CLI"
        "pCloud Drive"
    )

    local selected=$(show_multiselect "Select optional packages to install:" "${options[@]}")

    if [[ -n "$selected" ]]; then
        IFS=',' read -ra INDICES <<< "$selected" || true
        for idx in "${INDICES[@]}"; do
            case $idx in
                0) INSTALL_CLAUDE=true ;;
                1) INSTALL_GITHUB=true ;;
                2) INSTALL_GCLOUD=true ;;
                3) INSTALL_PCLOUD=true ;;
            esac
        done
        INSTALL_OPTIONAL=true
        INSTALL_SUMMARY+=("Optional packages configured.")
    else
        print_info "No optional packages selected."
    fi
}

update_system() {
    clear_screen
    print_section "SYSTEM UPDATE"

    print_info "Refreshing package databases and upgrading system packages..."
    print_step "Running pacman -Syu..."
    if sudo pacman -Syu --noconfirm; then
        print_success "System updated successfully."
        INSTALL_SUMMARY+=("System was updated.")
    else
        print_warning "System update had issues, continuing..."
    fi
    echo ""
}

install_yay() {
    if command_exists yay; then
        print_success "Yay is already installed"
        return 0
    fi

    print_section "INSTALLING YAY AUR HELPER"

    print_info "Yay is required to install AUR packages"

    print_step "Installing yay dependencies (git, base-devel)..."
    sudo pacman -S --noconfirm --needed git base-devel
    print_success "Dependencies installed"

    print_step "Cloning yay repository from AUR..."
    local tmp_dir="/tmp/yay-install-$$"
    git clone https://aur.archlinux.org/yay-bin.git "$tmp_dir"
    print_success "Repository cloned"

    print_step "Building and installing yay (this may take a moment)..."
    cd "$tmp_dir"
    makepkg -si --noconfirm

    cd "$SCRIPT_DIR"
    rm -rf "$tmp_dir"

    if command_exists yay; then
        echo ""
        print_success "Yay AUR helper installed successfully!"
        INSTALL_SUMMARY+=("Yay AUR helper installed")
        return 0
    else
        print_error "Failed to install yay"
        return 1
    fi
}

# ====================================================================
# PACKAGE INSTALLATION
# ====================================================================

install_official_packages() {
    if [[ "$INSTALL_OFFICIAL" != true ]]; then
        return 0
    fi

    print_section "INSTALLING OFFICIAL PACKAGES"

    install_packages_with_progress ALL_OFFICIAL_PACKAGES "pacman"

    INSTALL_SUMMARY+=("Official packages installed")
}

install_aur_packages() {
    if [[ "$INSTALL_AUR" != true ]]; then
        return 0
    fi

    print_section "INSTALLING AUR PACKAGES"

    # Ensure yay is installed
    if ! command_exists yay; then
        install_yay || return 1
    fi

    install_packages_with_progress ALL_AUR_PACKAGES "yay"

    INSTALL_SUMMARY+=("AUR packages installed")
}

install_optional_packages_handler() {
    if [[ "$INSTALL_OPTIONAL" != true ]]; then
        return 0
    fi

    print_section "INSTALLING OPTIONAL PACKAGES"

    if [[ "$INSTALL_GITHUB" == true ]]; then
        print_info "Installing GitHub CLI..."
        install_packages_with_progress OPTIONAL_GITHUB_PACKAGES "pacman"
    fi

    if [[ "$INSTALL_GCLOUD" == true ]]; then
        print_info "Installing Google Cloud CLI packages..."
        install_packages_with_progress AUR_OPTIONAL_GCLOUD_PACKAGES "yay"
    fi

    if [[ "$INSTALL_PCLOUD" == true ]]; then
        print_info "Installing pCloud Drive..."
        install_packages_with_progress AUR_OPTIONAL_PCLOUD_PACKAGES "yay"
    fi

    if [[ "$INSTALL_CLAUDE" == true ]]; then
        print_info "Installing Claude Code..."
        if command_exists npm; then
            sudo npm install -g "${NPM_OPTIONAL_CLAUDE_PACKAGES[@]}"
            print_success "Claude Code installed"
        else
            print_warning "npm not found, skipping Claude Code installation"
        fi
    fi

    INSTALL_SUMMARY+=("Optional packages installed")
}

install_flatpak_packages() {
    if [[ "$INSTALL_FLATPAK" != true ]]; then
        return 0
    fi

    print_section "INSTALLING FLATPAK PACKAGES"

    print_step "Adding Flathub repository..."
    flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

    local total=${#FLATPAK_PACKAGES[@]}
    local current=0

    for pkg in "${FLATPAK_PACKAGES[@]}"; do
        current=$((current + 1))
        echo -e "${WHITE}[$current/$total]${NC} Installing ${YELLOW}$pkg${NC}..."
        flatpak install -y flathub "$pkg"
        show_progress "$current" "$total"
        echo ""
    done

    print_success "Flatpak packages installed"
    INSTALL_SUMMARY+=("Flatpak packages installed")
}

install_npm_packages() {
    if [[ "$INSTALL_NPM" != true ]]; then
        return 0
    fi

    print_section "INSTALLING NPM GLOBAL PACKAGES"

    # Reload shell hash table to recognize newly installed npm
    hash -r

    if ! command_exists npm; then
        print_warning "npm not found, skipping npm package installation"
        return 0
    fi

    local total=${#NPM_PACKAGES[@]}
    local current=0

    for pkg in "${NPM_PACKAGES[@]}"; do
        current=$((current + 1))
        echo -e "${WHITE}[$current/$total]${NC} Installing ${YELLOW}$pkg${NC}..."
        sudo npm install -g "$pkg"
        show_progress "$current" "$total"
        echo ""
    done

    print_success "NPM packages installed"
    INSTALL_SUMMARY+=("NPM global packages installed")
}

# ====================================================================
# CONFIGURATION DEPLOYMENT
# ====================================================================

restore_wm_configs() {
    print_section "RESTORING WINDOW MANAGER CONFIGURATIONS"

    local home_dir=$(get_home_dir)
    local config_dir="$home_dir/.config"

    # QuickShell
    if [ -d "$SCRIPT_DIR/configs/wm/quickshell/chima" ]; then
        print_step "Restoring QuickShell configuration..."
        ensure_directory "$config_dir/quickshell"
        cp -r "$SCRIPT_DIR/configs/wm/quickshell/chima" "$config_dir/quickshell/"
        print_success "QuickShell configuration restored"
    fi

    # Hyprland
    if [ -d "$SCRIPT_DIR/configs/wm/hyprland/hypr" ]; then
        print_step "Restoring Hyprland configuration..."
        ensure_directory "$config_dir"
        cp -r "$SCRIPT_DIR/configs/wm/hyprland/hypr" "$config_dir/"
        print_success "Hyprland configuration restored"
    fi

    # QuickShell user preferences (config.json + wallpaper)
    if [ -d "$SCRIPT_DIR/configs/wm/chima" ]; then
        print_step "Restoring QuickShell user preferences..."
        ensure_directory "$config_dir/chima"
        cp -r "$SCRIPT_DIR/configs/wm/chima"/* "$config_dir/chima/"
        print_success "QuickShell user preferences restored (monochrome setting + wallpaper)"
    fi
}

restore_editor_configs() {
    print_section "RESTORING EDITOR CONFIGURATIONS"

    local home_dir=$(get_home_dir)
    local config_dir="$home_dir/.config"

    # Neovim
    if [ -d "$SCRIPT_DIR/configs/editors/nvim/nvim" ]; then
        print_step "Restoring Neovim configuration..."
        ensure_directory "$config_dir"
        cp -r "$SCRIPT_DIR/configs/editors/nvim/nvim" "$config_dir/"
        print_success "Neovim configuration restored"
    fi

    # VS Code
    if [ -d "$SCRIPT_DIR/configs/editors/Code" ]; then
        print_step "Restoring VS Code configuration..."
        ensure_directory "$config_dir/Code/User"
        [ -f "$SCRIPT_DIR/configs/editors/Code/settings.json" ] && cp "$SCRIPT_DIR/configs/editors/Code/settings.json" "$config_dir/Code/User/"
        [ -f "$SCRIPT_DIR/configs/editors/Code/keybindings.json" ] && cp "$SCRIPT_DIR/configs/editors/Code/keybindings.json" "$config_dir/Code/User/"

        # Install extensions
        if [ -f "$SCRIPT_DIR/configs/editors/Code/extensions.txt" ]; then
            print_step "Installing VS Code extensions..."
            while IFS= read -r ext; do
                code --install-extension "$ext" &> /dev/null && print_info "  Installed: $ext"
            done < "$SCRIPT_DIR/configs/editors/Code/extensions.txt"
        fi

        print_success "VS Code configuration restored"
    fi
}

