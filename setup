}

restore_git_config() {
    print_section "RESTORING GIT CONFIGURATION"

    local home_dir=$(get_home_dir)

    if [ -f "$SCRIPT_DIR/configs/git/.gitconfig" ]; then
        print_step "Restoring .gitconfig..."
        cp "$SCRIPT_DIR/configs/git/.gitconfig" "$home_dir/"
        print_success "Git configuration restored"
    else
        print_warning "No .gitconfig found in backup"
        print_info "You will need to configure git manually (run configure_git)"
    fi
}

restore_wallpapers() {
    print_section "RESTORING WALLPAPERS"

    local home_dir=$(get_home_dir)

    print_step "Restoring wallpapers to ~/Pictures..."
    ensure_directory "$home_dir/Pictures"

    # Copy all wallpapers from wallpapers directory
    if [ -d "$SCRIPT_DIR/wallpapers" ]; then
        local count=$(find "$SCRIPT_DIR/wallpapers" -type f | wc -l)
        if [ $count -gt 0 ]; then
            cp -r "$SCRIPT_DIR/wallpapers"/* "$home_dir/Pictures/" 2>/dev/null
            print_success "Restored $count wallpaper(s) to ~/Pictures"
        else
            print_warning "No wallpapers found in backup"
        fi
    else
        print_warning "No wallpapers directory found"
    fi
}

restore_systemd_configs() {
    print_section "RESTORING SYSTEMD SERVICES"

    local home_dir=$(get_home_dir)

    # Create systemd user directory
    ensure_directory "$home_dir/.config/systemd/user"

    # Copy QuickShell service file
    if [ -f "$SCRIPT_DIR/configs/system/systemd/user/quickshell.service" ]; then
        print_step "Installing QuickShell systemd service..."
        cp "$SCRIPT_DIR/configs/system/systemd/user/quickshell.service" "$home_dir/.config/systemd/user/"
        print_success "QuickShell service installed"
    else
        print_warning "QuickShell service not found in backup"
    fi

    # Reload systemd daemon
    print_step "Reloading systemd daemon..."
    systemctl --user daemon-reload
    print_success "Systemd daemon reloaded"

    # Enable and start services
    local services_to_enable=(
        "quickshell.service"
        "ydotool.service"
        "hypridle.service"
    )

    print_step "Enabling systemd services..."
    local enabled_count=0
    for service in "${services_to_enable[@]}"; do
        if systemctl --user enable "$service" &> /dev/null; then
            ((enabled_count++))
            print_info "  ✓ Enabled $service"
        fi
    done

    if [ $enabled_count -gt 0 ]; then
        print_success "Enabled $enabled_count systemd service(s)"
        print_info "Services will start automatically on next login"
    else
        print_warning "No systemd services were enabled"
    fi
}

expand_home_variables() {
    print_section "EXPANDING \$HOME VARIABLES"

    local home_dir=$(get_home_dir)

    print_step "Expanding \$HOME in configuration files..."

    # List of all files that contain $HOME and need expansion
    local files_to_expand=(
        "$home_dir/.config/chima/config.json"
        "$home_dir/.config/hypr/hyprlock.conf"
        "$home_dir/.config/hypr/custom/keybinds.conf"
        "$home_dir/.config/matugen/templates/hyprland/hyprlock.conf"
        "$home_dir/.local/share/applications/whatsapp.desktop"
        "$home_dir/.config/btop/btop.conf"
    )

    local count=0
    for file in "${files_to_expand[@]}"; do
        if [ -f "$file" ]; then
            perl -pi -e 's/\$HOME/$ENV{HOME}/g' "$file"
            ((count++))
        fi
    done

    print_success "Expanded \$HOME in $count configuration files"
}

fix_script_permissions() {
    print_section "FIXING SCRIPT PERMISSIONS"

    local home_dir=$(get_home_dir)

    print_step "Making shell scripts executable..."

    # Explicit list of all .sh scripts that need to be executable
    local scripts=(
        # SDDM Theme (installed to system path)
        "/usr/share/sddm/themes/chima/backgrounds/extract_first_frame.sh"
        "/usr/share/sddm/themes/chima/change_avatar.sh"
        "/usr/share/sddm/themes/chima/test.sh"
        # Matugen
        "$home_dir/.config/matugen/templates/kde/kde-material-you-colors-wrapper.sh"
        # Hyprland
        "$home_dir/.config/hypr/hyprland/launcher.sh"
        "$home_dir/.config/hypr/custom/scripts/launcher.sh"
        "$home_dir/.config/hypr/custom/scripts/__restore_video_wallpaper.sh"
        "$home_dir/.config/hypr/hyprland/scripts/fuzzel-emoji.sh"
        "$home_dir/.config/hypr/hyprland/scripts/launch_first_available.sh"
        "$home_dir/.config/hypr/hyprland/scripts/record.sh"
        "$home_dir/.config/hypr/hyprland/scripts/start_geoclue_agent.sh"
        "$home_dir/.config/hypr/hyprland/scripts/workspace_action.sh"
        "$home_dir/.config/hypr/hyprland/scripts/zoom.sh"
        "$home_dir/.config/hypr/hyprlock/check-capslock.sh"
        "$home_dir/.config/hypr/hyprlock/status.sh"
        # QuickShell
        "$home_dir/.config/quickshell/chima/scripts/colors/applycolor.sh"
        "$home_dir/.config/quickshell/chima/scripts/colors/random_konachan_wall.sh"
        "$home_dir/.config/quickshell/chima/scripts/colors/switchwall.sh"
        "$home_dir/.config/quickshell/chima/scripts/hypridle-manager.sh"
        "$home_dir/.config/quickshell/chima/scripts/hyprland-settings.sh"
        "$home_dir/.config/quickshell/chima/scripts/kvantum/materialQT.sh"
        "$home_dir/.config/quickshell/chima/scripts/switch-hyprlock-wallpaper.sh"
        "$home_dir/.config/quickshell/chima/scripts/wallpaper-manager.sh"
    )

    local count=0
    for script in "${scripts[@]}"; do
        if [ -f "$script" ]; then
            chmod +x "$script"
            ((count++))
        fi
    done

    print_success "Made $count shell scripts executable"
}

deploy_configurations() {
    if [[ "$INSTALL_CONFIGS" != true ]]; then
        return 0
    fi

    print_section "DEPLOYING CONFIGURATIONS"

    print_info "This will restore all configurations..."
    echo ""

    # Restore all configs
    restore_wm_configs
    restore_editor_configs
    restore_shell_configs
    restore_terminal_configs
    restore_dev_configs
    restore_app_configs
    restore_theme_configs
    restore_git_config
    restore_wallpapers

    # Restore systemd services
    restore_systemd_configs

    # Expand $HOME variables in all config files
    expand_home_variables

    # Fix script permissions
    fix_script_permissions

    echo ""
    print_success "All configurations deployed successfully!"
    INSTALL_SUMMARY+=("Configurations deployed")
}

# ====================================================================
# SERVICES SETUP
# ====================================================================

setup_system_services() {
    print_section "CONFIGURING SYSTEM SERVICES"

    local home_dir=$(get_home_dir)

    print_info "Enabling system services to start on boot..."

    local services=(
        "bluetooth.service"
        "docker.service"
        "NetworkManager.service"
        "sddm.service"
        "tlp.service"
    )

    for service in "${services[@]}"; do
        print_step "Enabling $service..."
        if sudo systemctl enable "$service" &> /dev/null; then
            print_success "Enabled $service"
        else
            print_info "Service $service not available or already enabled"
        fi
    done

    # Enable timers
    print_step "Enabling fstrim.timer..."
    sudo systemctl enable fstrim.timer &> /dev/null && print_success "fstrim.timer enabled"

    print_success "System services configured"
}

setup_user_services() {
    print_section "CONFIGURING USER SERVICES"

    local services=(
        "hypridle.service"
        "wireplumber.service"
        "ydotool.service"
        "pipewire.socket"
        "pipewire-pulse.socket"
    )

    for service in "${services[@]}"; do
        print_step "Enabling $service..."
        if systemctl --user enable "$service" &> /dev/null; then
            print_success "Enabled $service"
        else
            print_info "Service $service not available or already enabled"
        fi
    done

    print_success "User services configured"
}

setup_user_groups() {
    print_section "CONFIGURING USER GROUPS"

    local username=$(get_username)
    local groups=(
        "docker"
        "wheel"
        "video"
        "audio"
        "input"
    )

    for group in "${groups[@]}"; do
        if ! groups $username | grep -q "\b$group\b"; then
            print_step "Adding $username to $group group..."
            sudo usermod -aG "$group" "$username"
            print_success "Added to $group"
        else
            print_info "Already in $group group"
        fi
    done

    print_warning "You may need to log out and log back in for group changes to take effect"
}

setup_sddm_theme() {
    print_section "SETTING UP SDDM CUSTOM THEME"

    local theme_source="$SCRIPT_DIR/configs/system/sddm/chima"
    local theme_dest="/usr/share/sddm/themes/chima"
    local home_dir=$(get_home_dir)

    # Check if theme exists in backup
    if [ ! -d "$theme_source" ]; then
        print_warning "SDDM theme not found in configs, skipping..."
        return 0
    fi

    print_step "Installing chima theme..."
    sudo cp -r "$theme_source" "$theme_dest" 2>/dev/null

    if [ $? -eq 0 ]; then
        print_success "SDDM theme installed to $theme_dest"
    else
        print_error "Failed to install SDDM theme"
        return 0
    fi

    # Configure SDDM to use the theme
    print_step "Configuring SDDM to use chima theme..."

    sudo mkdir -p /etc/sddm.conf.d

    # Deploy the full sddm.conf (numlock, HiDPI, avatars, session settings, etc.)
    local sddm_conf_source="$SCRIPT_DIR/configs/system/sddm/sddm.conf"
    if [ -f "$sddm_conf_source" ]; then
        sudo cp "$sddm_conf_source" /etc/sddm.conf
        print_success "SDDM system configuration deployed"
    else
        # Fallback: minimal theme-only config
        sudo tee /etc/sddm.conf.d/theme.conf > /dev/null << EOF
[Theme]
Current=chima
EOF
    fi

    # Deploy kde_settings.conf to override KDE/Plasma defaults
    local kde_conf_source="$SCRIPT_DIR/configs/system/sddm/kde_settings.conf"
    if [ -f "$kde_conf_source" ]; then
        sudo cp "$kde_conf_source" /etc/sddm.conf.d/kde_settings.conf
        print_success "SDDM KDE settings override deployed"
    fi

    print_success "SDDM configured to use chima theme"

    # Copy wallpaper if exists
    if [ -f "$home_dir/Pictures/DarkSide.png" ]; then
        print_step "Copying wallpaper to SDDM theme..."
        sudo cp "$home_dir/Pictures/DarkSide.png" "$theme_dest/backgrounds/" 2>/dev/null
        print_success "Wallpaper copied"
    else
        print_info "DarkSide.png will be added when wallpapers are restored"
    fi

    # Deploy user avatar for SDDM
    local avatar_source="$SCRIPT_DIR/wallpapers/Profile.jpg"
    local username
    username=$(get_username)
    local faces_dir="/usr/share/sddm/faces"

    if [ -f "$avatar_source" ]; then
        print_step "Deploying user avatar for SDDM..."
        sudo mkdir -p "$faces_dir"
        sudo cp "$avatar_source" "$faces_dir/${username}.face.icon"
        print_success "User avatar deployed to $faces_dir/${username}.face.icon"
    else
        print_info "Profile.jpg not found, skipping avatar deployment"
    fi

    print_success "SDDM theme setup complete"
}

setup_grub() {
    print_section "SETTING UP GRUB CONFIGURATION"

    local grub_source="$SCRIPT_DIR/configs/system/grub/grub"
    local grub_dest="/etc/default/grub"
    local theme_source="$SCRIPT_DIR/configs/system/grub/chima"
    local theme_dest="/boot/grub/themes/chima"

    # Backup current GRUB config
    if [ -f "$grub_dest" ]; then
        print_step "Backing up current GRUB configuration..."
        sudo cp "$grub_dest" "$grub_dest.backup.$(date +%Y%m%d_%H%M%S)"
        print_success "GRUB config backed up"
    fi

    # STEP 1: Install chima theme FIRST (before copying config that references it)
    if [ -d "$theme_source" ]; then
        print_step "Installing chima GRUB theme..."
        sudo mkdir -p /boot/grub/themes
        sudo cp -r "$theme_source" "$theme_dest" 2>/dev/null

        if [ $? -eq 0 ]; then
            print_success "chima theme installed to $theme_dest"
        else
            print_error "Failed to install GRUB theme"
            print_warning "GRUB will use default theme"
        fi
    else
        print_warning "GRUB theme not found in backup, skipping..."
    fi

    # STEP 2: Restore GRUB config (theme now exists)
    if [ -f "$grub_source" ]; then
        print_step "Restoring GRUB configuration..."
        sudo cp "$grub_source" "$grub_dest"
        print_success "GRUB config restored"
    else
        print_info "GRUB config not found in backup, skipping..."
        return 0
    fi

    # STEP 3: Regenerate GRUB configuration
    print_step "Regenerating GRUB configuration..."
    if sudo grub-mkconfig -o /boot/grub/grub.cfg &> /dev/null; then
        print_success "GRUB configuration regenerated"
    else
        print_error "Failed to regenerate GRUB configuration"
        print_warning "You may need to run: sudo grub-mkconfig -o /boot/grub/grub.cfg"
        return 0
    fi

    print_success "GRUB setup complete (theme: chima)"
}

setup_tlp() {
    print_section "SETTING UP TLP POWER MANAGEMENT"

    local tlp_source="$SCRIPT_DIR/configs/system/tlp/tlp.conf"
    local tlp_dest="/etc/tlp.conf"

    if [ ! -f "$tlp_source" ]; then
        print_info "TLP config not found in backup, skipping..."
        return 0
    fi

    print_step "Backing up current TLP configuration..."
    if [ -f "$tlp_dest" ]; then
        sudo cp "$tlp_dest" "$tlp_dest.backup.$(date +%Y%m%d_%H%M%S)"
        print_success "TLP config backed up"
    fi

    print_step "Restoring TLP configuration..."
    sudo cp "$tlp_source" "$tlp_dest"
    print_success "TLP configuration restored"

    print_success "TLP setup complete"
}

setup_services() {
    # Call all service setup functions
    setup_system_services
    setup_user_services
    setup_user_groups
    setup_sddm_theme
    setup_grub
    setup_tlp

    INSTALL_SUMMARY+=("System services configured")
}

# ====================================================================
# POST-INSTALLATION
# ====================================================================

post_installation() {
    print_section "POST-INSTALLATION TASKS"

    print_info "Performing final system configuration..."

    print_step "Rebuilding font cache..."
    fc-cache -fv > /dev/null 2>&1
    print_success "Font cache rebuilt successfully"

    print_step "Updating desktop database..."
    update-desktop-database ~/.local/share/applications/ > /dev/null 2>&1 || true
    print_success "Desktop database updated"

    print_step "Configuring default shell..."
    if command_exists fish; then
        if ! grep -q "$(which fish)" /etc/shells; then
            echo "$(which fish)" | sudo tee -a /etc/shells > /dev/null
            print_info "Added fish to /etc/shells"
        fi
        sudo chsh -s "$(which fish)" "$USER"
        print_success "Default shell changed to fish"
    else
        print_info "Fish shell not installed, keeping current shell"
    fi

    print_step "Installing Hyprland plugins via hyprpm..."
    if command_exists hyprpm; then
        # hyprpm needs to run as the actual user, not root
        sudo -u "$(get_username)" hyprpm update > /dev/null 2>&1 || true
        sudo -u "$(get_username)" hyprpm add https://github.com/hyprwm/hyprland-plugins > /dev/null 2>&1 || true
        sudo -u "$(get_username)" hyprpm enable hyprbars > /dev/null 2>&1 || true
        print_success "Hyprland plugins installed (hyprbars)"
    else
        print_warning "hyprpm not found, plugins will need to be installed manually"
    fi

    print_step "Generating initial QuickShell theme colors..."
    local home_dir=$(get_home_dir)
    local switchwall_script="$home_dir/.config/quickshell/chima/scripts/colors/switchwall.sh"
    if [ -f "$switchwall_script" ]; then
        # Run as the actual user (not sudo) to generate colors in their home directory
        # Let the script complete fully, just suppress output
        sudo -u "$(get_username)" bash "$switchwall_script" --noswitch > /dev/null 2>&1 || true
        print_success "Initial theme colors generated"
    else
        print_warning "QuickShell switchwall script not found, colors will be generated on first launch"
    fi

    echo ""
    print_success "Post-installation tasks completed!"
    INSTALL_SUMMARY+=("Post-installation tasks completed")
}

# ====================================================================
# GIT CONFIGURATION
# ====================================================================

configure_git() {
    print_section "GIT CONFIGURATION"

    print_info "Git requires your name and email for commits."
    echo ""

    # Get git username
    echo -e "${CYAN}Enter your full name (for git commits):${NC}"
    read -p "> " git_name

    # Get git email
    echo -e "${CYAN}Enter your email (for git commits):${NC}"
    read -p "> " git_email

    # Configure git
    if [[ -n "$git_name" ]] && [[ -n "$git_email" ]]; then
        print_step "Configuring git globally..."
        git config --global user.name "$git_name"
        git config --global user.email "$git_email"
        git config --global core.editor "nvim"
        git config --global init.defaultBranch "main"
        print_success "Git configured successfully"
        print_info "Name: $git_name"
        print_info "Email: $git_email"
        INSTALL_SUMMARY+=("Git configured")
    else
        print_warning "Git configuration skipped (empty input)"
    fi

    echo ""

    # SSH key generation
    if ask_yes_no "Generate SSH key for git/GitHub?" "y"; then
        print_step "Generating SSH key..."
        ssh-keygen -t ed25519 -C "$git_email" -f "$HOME/.ssh/id_ed25519" -N ""

        print_step "Starting ssh-agent..."
        eval "$(ssh-agent -s)" > /dev/null
        ssh-add "$HOME/.ssh/id_ed25519"

        print_success "SSH key generated: ~/.ssh/id_ed25519.pub"
        echo ""
        print_info "Your public SSH key:"
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        cat "$HOME/.ssh/id_ed25519.pub"
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        print_info "Add this key to GitHub: https://github.com/settings/keys"
        INSTALL_SUMMARY+=("SSH key generated")
        press_any_key
    fi
}

# ====================================================================
# COMPLETION
# ====================================================================

show_completion() {
    clear
    print_header "INSTALLATION COMPLETE!"

    show_summary INSTALL_SUMMARY

    local term_width=$(get_terminal_width)
    local separator=$(printf '━%.0s' $(seq 1 $term_width))

    echo -e "${GREEN}${separator}${NC}"
    echo -e "${GREEN}  Next Steps:${NC}"
    echo -e "${GREEN}${separator}${NC}"
    echo ""
    echo -e "  ${CYAN}1.${NC} Reboot your system: ${YELLOW}sudo reboot${NC}"
    echo -e "  ${CYAN}2.${NC} Log in through SDDM"
    echo -e "  ${CYAN}3.${NC} Select Hyprland as your session"
    echo -e "  ${CYAN}4.${NC} Enjoy your new setup!"
    echo ""

    if [[ "$INSTALL_GITHUB" == true ]] || [[ "$INSTALL_GCLOUD" == true ]] || [[ "$INSTALL_PCLOUD" == true ]] || [[ "$INSTALL_CLAUDE" == true ]]; then
        print_warning "Remaining authentication steps:"
        [[ "$INSTALL_GITHUB" == true ]] && echo -e "  ${CYAN}*${NC} GitHub CLI: ${YELLOW}gh auth login${NC}"
        [[ "$INSTALL_GCLOUD" == true ]] && echo -e "  ${CYAN}*${NC} Google Cloud: ${YELLOW}gcloud auth login${NC}"
        [[ "$INSTALL_PCLOUD" == true ]] && echo -e "  ${CYAN}*${NC} pCloud: Launch and sign in"
        [[ "$INSTALL_CLAUDE" == true ]] && echo -e "  ${CYAN}*${NC} Claude Code: Follow authentication prompts"
        echo ""
    fi

    draw_box "Thank you for using Chima!"
    echo ""
}

main() {
    # Pre-flight checks (before sudo)
    perform_system_checks

    # Request sudo password upfront
    print_section "SUDO ACCESS REQUIRED"
    print_info "This installation requires administrative privileges."
    print_step "Requesting sudo access..."

    if ! sudo -v; then
        echo ""
        print_error "Failed to obtain sudo access"
        print_info "Installation cancelled"
        exit 1
    fi

    print_success "Sudo access granted"
    echo ""

    # Keep sudo alive in the background
    while true; do
        sudo -n true
        sleep 60
        kill -0 "$$" || exit
    done 2>/dev/null &

    show_welcome

    select_installation_mode

    clear_screen
    print_section "SUMMARY"
    echo -e "${CYAN}Core Installation:${NC}"
    echo -e "  Official Repository Packages"
    echo -e "  AUR Packages"
    echo -e "  Fonts & Themes"
    echo -e "  System Configurations"
    echo -e "  Flatpak Packages"
    echo -e "  NPM Global Packages"
    echo ""
    echo -e "${CYAN}Optional Packages:${NC}"
    echo -e "  Claude Code:  ${BRIGHT_CYAN}$INSTALL_CLAUDE${NC}"
    echo -e "  GitHub CLI:   ${BRIGHT_CYAN}$INSTALL_GITHUB${NC}"
    echo -e "  Google Cloud: ${BRIGHT_CYAN}$INSTALL_GCLOUD${NC}"
    echo -e "  pCloud Drive: ${BRIGHT_CYAN}$INSTALL_PCLOUD${NC}"

    if ! confirm_action "Proceed with installation?" "y"; then
        print_error "Installation cancelled."
        exit 0
    fi

    update_system

    install_yay
    install_official_packages
    install_aur_packages
    install_optional_packages_handler
    install_flatpak_packages
    install_npm_packages

    deploy_configurations

    setup_services

    post_installation

    configure_git

    show_completion
}

main "$@"
