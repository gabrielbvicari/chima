    [ -d "$SCRIPT_DIR/configs/theme/qt6ct" ] && cp -r "$SCRIPT_DIR/configs/theme/qt6ct" "$config_dir/" && print_success "qt6ct theme restored"

    # Matugen
    if [ -d "$SCRIPT_DIR/configs/theme/matugen/matugen" ]; then
        print_step "Restoring Matugen templates..."
        ensure_directory "$config_dir"
        cp -r "$SCRIPT_DIR/configs/theme/matugen/matugen" "$config_dir/"
        print_success "Matugen templates restored"
